# EditorConfig helps developers define and maintain consistent
# coding styles between different editors and IDEs
# editorconfig.org

root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{diff,md}]
trim_trailing_whitespace = false

[*.py]
indent_size = 4
max_line_length = 88
python_autopep8 = true
isort_additional_settings = true
black_line_length = 88

[*.tf]
indent_size = 2
indent_style = space

[*.yaml]
[*.yml]
indent_size = 2
indent_style = space

[*.json]
indent_size = 2
indent_style = space

[Makefile]
indent_style = tab

[*.html]
indent_size = 2
indent_style = space

[*.css]
indent_size = 2
indent_style = space

[*.js]
indent_size = 2
indent_style = space

[*.ts]
indent_size = 2
indent_style = space

[*.sh]
indent_size = 2
indent_style = space

[{go.mod,go.sum,*.go}]
indent_style = tab
indent_size = 4
